# Environment Configuration for Playwright E2E Tests

# Application URL
BASE_URL=https://www.maisononline.vn/?view=men

# API Configuration
API_TIMEOUT=30000
API_BASE_URL=https://api.maisononline.vn

# Test Environment
ENVIRONMENT=local
# Options: local, staging, production

# Browser & Execution
HEADED=false
# Set to true to run tests in headed mode (visible browser)

SLOW_MO=0
# Slow down test execution (milliseconds)

# Retry Configuration
RETRIES=1
# Number of retries for failed tests

# Parallel Workers
WORKERS=4
# Number of parallel test workers

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# CI/CD
CI=false
# Set to true when running in CI environment

# Timeout Settings
NAVIGATION_TIMEOUT=30000
# Timeout for page navigation (ms)

ACTION_TIMEOUT=10000
# Timeout for user actions (ms)

# Screenshot & Video
SCREENSHOT=only-on-failure
# Options: off, on, only-on-failure

VIDEO=retain-on-failure
# Options: off, on, retain-on-failure

# Test Data
TEST_DATA_PROVIDER=local
# Options: local, remote, database
